# App
NEXT_PUBLIC_APP_URL=https://labelpilot.de
NODE_ENV=development
# Optional public feature flags
NEXT_PUBLIC_FEATURE_CUSTOM_SIZE=false
NEXT_PUBLIC_FEATURE_ADDONS=false

# Analytics — Google Analytics 4 + Ads
# GA4 Measurement ID (format: G-XXXXXXXXXX) — leave empty to disable
NEXT_PUBLIC_GA_MEASUREMENT_ID=
# Google Ads conversion tracking (format: AW-XXXXXXXXXX)
NEXT_PUBLIC_ADS_CONVERSION_ID=
# Google Ads purchase conversion label (from the conversion action setup)
NEXT_PUBLIC_ADS_CONVERSION_LABEL_PURCHASE=

# Database
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/labelpilot?schema=public
DIRECT_URL=postgresql://USER:PASSWORD@HOST:5432/labelpilot?schema=public

# Supabase / Auth / Storage
SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=labelpilot-private-files
SUPABASE_ARTWORK_BUCKET=artwork

# Email
# Resend API key for transactional order emails
RESEND_API_KEY=
# Verified sender, e.g. Labelpilot.de <bestellungen@labelpilot.de>
EMAIL_FROM=Labelpilot.de <bestellungen@labelpilot.de>
# Reply-to inbox for customer responses
EMAIL_REPLY_TO=kontakt@labelpilot.de
# Internal notification inbox for new orders, artwork uploads and leads.
# Falls back to EMAIL_REPLY_TO when unset.
ADMIN_NOTIFY_EMAIL=

# Stripe (use LIVE keys in production)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Internal operator APIs
APP_SECRET=
# Vercel Cron auth: Vercel sends "Authorization: Bearer ${CRON_SECRET}" to cron
# routes when this is set. Required for /api/cron/refill-reminders to run.
CRON_SECRET=
# Set to "true" to enable the daily reorder-reminder cron.
ENABLE_REORDER_REMINDERS=

# Admin gate — Supabase session is primary; the email below is the allowed admin.
# Basic Auth is the fallback when Supabase env is not configured.
ADMIN_EMAIL=
ADMIN_BASIC_USER=
ADMIN_BASIC_PASSWORD=

# Live chat (Telegram operator bridge) — optional
TELEGRAM_BOT_TOKEN=
TELEGRAM_OPERATOR_CHAT_ID=
# Required for the Telegram webhook to accept updates (fails closed when unset)
CHAT_WEBHOOK_SECRET=
