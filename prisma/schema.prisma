generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum OrderStatus {
  DRAFT
  QUOTE_REQUESTED
  PENDING_PAYMENT
  PAID
  PAYMENT_FAILED
  FILE_REVIEW
  CORRECTION_REQUIRED
  ON_HOLD
  PROOF_REQUIRED
  WAITING_CUSTOMER_APPROVAL
  APPROVED_FOR_PRODUCTION
  IN_PRODUCTION
  READY_TO_SHIP
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
  REFUND_REQUESTED
  REPRINT_REQUIRED
}

enum QuoteStatus {
  NEW
  UNDER_REVIEW
  NEEDS_MORE_INFO
  QUOTE_SENT
  ACCEPTED
  REJECTED
  EXPIRED
  CONVERTED_TO_ORDER
}

enum LeadType {
  QUOTE_REQUEST
  SAMPLE_BOX_REQUEST
  CONTACT_REQUEST
  OUTBOUND_PROSPECT
  REORDER_INTEREST
  BULK_ORDER_INTEREST
}

enum LeadStatus {
  NEW
  QUALIFYING
  QUALIFIED
  SAMPLE_SENT
  QUOTE_NEEDED
  QUOTE_SENT
  FOLLOW_UP
  WON
  LOST
  DISQUALIFIED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
  REFUNDED
  PARTIALLY_REFUNDED
  DISPUTED
}

enum StripeEventStatus {
  RECEIVED
  PROCESSED
  ERROR
}

enum ArtworkFileStatus {
  UPLOADED
  UNDER_REVIEW
  APPROVED
  CORRECTION_REQUIRED
}

enum ArtworkStatus {
  AWAITING_ARTWORK
  ARTWORK_UPLOADED
  ARTWORK_APPROVED
}

enum ProofFileStatus {
  NOT_REQUIRED
  PENDING_ADMIN_UPLOAD
  WAITING_CUSTOMER_APPROVAL
  APPROVED
  CHANGES_REQUESTED
  SUPERSEDED
}

enum StoredDesignStatus {
  ACTIVE
  ARCHIVED
  NEEDS_REVIEW
  LOCKED
}

enum ArtworkVersionSourceType {
  CUSTOMER_UPLOAD
  ADMIN_UPLOAD
  TEMPLATE_GENERATED
  VARIABLE_DATA_GENERATED
  REORDER_MINOR_CHANGE
}

enum ArtworkVersionStatus {
  DRAFT
  UPLOADED
  UNDER_REVIEW
  APPROVED
  REPLACED
  ARCHIVED
  REJECTED
}

model QuoteRequest {
  id                 String      @id @default(cuid())
  status             QuoteStatus @default(NEW)
  companyName        String
  contactName        String?
  email              String
  phone              String?
  country            String      @default("DE")
  website            String?
  industry           String?
  productType        String?
  labelSize          String?
  material           String?
  quantity           String?
  recurringNeed      String?
  targetDeliveryDate DateTime?
  hasArtwork         Boolean?
  notes              String?
  adminNote          String?
  source             String?
  sourcePage         String?
  convertedOrderId   String?
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt

  @@index([status])
  @@index([source])
  @@index([email])
  @@index([createdAt])
}

model Lead {
  id                  String     @id @default(cuid())
  type                LeadType
  status              LeadStatus @default(NEW)
  score               Int        @default(0)
  quality             String?
  companyName         String?
  contactName         String?
  email               String
  phone               String?
  country             String     @default("DE")
  website             String?
  industry            String?
  productType         String?
  labelSize           String?
  material            String?
  quantity            String?
  recurringNeed       String?
  targetDeliveryDate  DateTime?
  hasArtwork          Boolean?
  notes               String?
  sourceType          String?
  sourcePage          String?
  utmSource           String?
  utmMedium           String?
  utmCampaign         String?
  utmTerm             String?
  utmContent          String?
  referrer            String?
  landingPage         String?
  assignedToUserId    String?
  convertedCustomerId String?
  convertedOrderId    String?
  nextFollowUpAt      DateTime?
  followUpReason      String?
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt

  @@index([type, status])
  @@index([email])
  @@index([createdAt])
}

model Customer {
  id          String   @id @default(cuid())
  authUserId  String?  @unique
  email       String   @unique
  companyName String?
  contactName String?
  phone       String?
  street               String?
  addressLine2         String?
  postalCode           String?
  city                 String?
  country              String?
  vatId                String?
  billingCompanyName   String?
  billingStreet        String?
  billingAddressLine2  String?
  billingPostalCode    String?
  billingCity          String?
  billingCountry       String?
  notificationPrefs    Json?
  paymentTermsApproved Boolean  @default(false)
  paymentTermsNetDays  Int?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  orders      Order[]
  storedDesigns StoredDesign[]
  supportRequests SupportRequest[]

  @@index([email])
  @@index([authUserId])
}

model SupportRequest {
  id         String   @id @default(cuid())
  customerId String
  orderId    String?
  type       String   @default("GENERAL")
  subject    String
  message    String
  status     String   @default("OPEN")
  adminNote  String?
  attachments Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  order      Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)

  @@index([customerId])
  @@index([status])
}

model Order {
  id                      String             @id @default(cuid())
  orderNumber             String             @unique
  status                  OrderStatus        @default(PENDING_PAYMENT)
  artworkStatus           ArtworkStatus      @default(AWAITING_ARTWORK)
  productSlug             String
  material                String
  quantity                Int
  packageId               String?
  widthMm                 Int?
  heightMm                Int?
  amountCents             Int
  designServiceCents      Int?
  physicalProofCents      Int?
  expressCents            Int?
  extraDesignCount        Int                @default(0)
  extraDesignCents        Int?
  addonsTotalCents        Int?
  currency                String             @default("EUR")
  customerEmail           String
  customerName            String?
  companyName             String?
  customerPhone           String?
  vatId                   String?
  country                 String             @default("DE")
  streetAddress           String?
  addressLine2            String?
  postalCode              String?
  city                    String?
  billingCompanyName      String?
  billingStreetAddress    String?
  billingAddressLine2     String?
  billingPostalCode       String?
  billingCity             String?
  billingCountry          String?
  customerNote            String?
  artworkInputStatus      String?
  selectedAddons          Json?
  stripeCheckoutSessionId String?            @unique
  stripePaymentIntentId   String?
  customerId              String?
  reorderSourceDesignId   String?
  reorderSourceArtworkVersionId String?
  reorderMode             String?
  reorderStockDuration    String?
  finishing               String?
  tiefkuehlgeeignet       Boolean  @default(false)
  form                    String?
  klebertyp               String?
  uvLack                  String?
  cornerRadiusMm          Int?
  rollKern                String?
  abrollrichtung          String?
  maxRollendurchmesser    String?
  maschineName            String?
  shippingMode            String?
  shippingCarrier         String?
  trackingNumber          String?
  trackingUrl             String?
  packageCount            Int?
  shipmentWeightKg        Float?
  shippedAt               DateTime?
  estimatedDeliveryAt     DateTime?
  deliveredAt             DateTime?
  shipmentNote            String?
  uploadToken             String             @unique @default(uuid())
  uploadTokenExpiresAt    DateTime?
  confirmationEmailSentAt DateTime?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  artworkFiles            ArtworkFile[]
  proofFiles              ProofFile[]
  payments                Payment[]
  statusEvents            OrderStatusEvent[]
  adminNotes              OrderAdminNote[]
  refillPredictions       RefillPrediction[]
  reorderReminders        ReorderReminder[]
  variableDataBatches     VariableDataBatch[]
  supportRequests         SupportRequest[]
  customer                Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  storedDesigns           StoredDesign[]    @relation("StoredDesignLastOrder")

  @@index([status])
  @@index([customerEmail])
  @@index([customerId])
  @@index([createdAt])
  @@index([productSlug, material, quantity])
  @@index([packageId])
  @@index([reorderSourceDesignId])
  @@index([reorderSourceArtworkVersionId])
}

model RefillPrediction {
  id                  String   @id @default(cuid())
  orderId             String
  sourceDesignId      String?
  reorderStockDuration String
  predictedDepletionAt DateTime
  reminderEligibleAt   DateTime?
  reminderWindowDays   Int      @default(30)
  algorithmVersion     String   @default("v1")
  isEnabled            Boolean  @default(false)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  order                Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  reminders            ReorderReminder[]

  @@index([orderId])
  @@index([sourceDesignId])
  @@index([predictedDepletionAt])
}

model ReorderReminder {
  id                 String   @id @default(cuid())
  orderId            String
  refillPredictionId String?
  channel            String   @default("EMAIL")
  status             String   @default("DRAFT")
  scheduledFor       DateTime
  sentAt             DateTime?
  clickedAt          DateTime?
  clickToken         String?  @unique
  isEnabled          Boolean  @default(false)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  order              Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  refillPrediction   RefillPrediction? @relation(fields: [refillPredictionId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([refillPredictionId])
  @@index([scheduledFor])
}

model StoredDesign {
  id                      String             @id @default(cuid())
  customerId              String?
  name                    String
  productSlug             String
  labelSize               String?
  material                String?
  finishing               String?
  defaultQuantity         Int?
  status                  StoredDesignStatus @default(ACTIVE)
  currentArtworkVersionId String?
  currentProofFileId      String?
  lastOrderedAt           DateTime?
  lastOrderId             String?
  totalOrders             Int                @default(0)
  customerNotes           String?
  adminProductionNotes    String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  archivedAt              DateTime?
  artworkVersions         ArtworkVersion[]
  currentArtworkVersion   ArtworkVersion?    @relation("StoredDesignCurrentVersion", fields: [currentArtworkVersionId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  currentProofFile        ProofFile?         @relation(fields: [currentProofFileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  lastOrder               Order?             @relation("StoredDesignLastOrder", fields: [lastOrderId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  designVariables         DesignVariable[]
  variableDataBatches     VariableDataBatch[]
  customer                Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@index([customerId])
  @@index([productSlug])
  @@index([status])
  @@index([lastOrderedAt])
}

model DesignVariable {
  id            String   @id @default(cuid())
  storedDesignId String
  key           String
  label         String
  variableType  String
  isRequired    Boolean  @default(true)
  sortOrder     Int      @default(0)
  placeholder   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  storedDesign  StoredDesign @relation(fields: [storedDesignId], references: [id], onDelete: Cascade)

  @@unique([storedDesignId, key])
  @@index([storedDesignId])
}

model VariableDataBatch {
  id             String   @id @default(cuid())
  storedDesignId String?
  orderId        String?
  fileName       String
  fileType       String
  status         String   @default("DRAFT")
  totalRows      Int      @default(0)
  validRows      Int      @default(0)
  invalidRows    Int      @default(0)
  uploadedAt     DateTime @default(now())
  reviewedAt     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  storedDesign   StoredDesign? @relation(fields: [storedDesignId], references: [id], onDelete: SetNull)
  order          Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  generatedPrintFile GeneratedPrintFile?
  rows           VariableDataRow[]

  @@index([storedDesignId])
  @@index([orderId])
  @@index([status])
}

model VariableDataRow {
  id               String   @id @default(cuid())
  batchId          String
  rowIndex         Int
  payload          Json
  validationErrors Json?
  isValid          Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  batch            VariableDataBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@unique([batchId, rowIndex])
  @@index([batchId])
  @@index([isValid])
}

model GeneratedPrintFile {
  id         String   @id @default(cuid())
  batchId    String   @unique
  status     String   @default("PLACEHOLDER_READY")
  fileName   String
  mimeType   String   @default("text/csv")
  rowCount   Int
  checksum   String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  batch      VariableDataBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([status])
}

model ArtworkVersion {
  id                    String                   @id @default(cuid())
  storedDesignId        String
  versionNumber         Int
  versionLabel          String
  sourceType            ArtworkVersionSourceType
  originalArtworkFileId String?
  generatedPrintFileId  String?
  proofFileId           String?
  status                ArtworkVersionStatus     @default(UPLOADED)
  changeSummary         String?
  uploadedByUserId      String?
  approvedByAdminId     String?
  approvedAt            DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  storedDesign          StoredDesign             @relation(fields: [storedDesignId], references: [id], onDelete: Cascade)
  currentForDesign      StoredDesign[]           @relation("StoredDesignCurrentVersion")
  proofFile             ProofFile?               @relation(fields: [proofFileId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  originalArtworkFile   ArtworkFile?             @relation(fields: [originalArtworkFileId], references: [id], onDelete: SetNull, onUpdate: Cascade)

  @@unique([storedDesignId, versionNumber])
  @@index([storedDesignId])
  @@index([status])
  @@index([approvedAt])
}

model OrderAdminNote {
  id                String   @id @default(cuid())
  orderId           String
  noteType          String   @default("INTERNAL")
  isCustomerVisible Boolean  @default(false)
  actor             String?
  body              String
  createdAt         DateTime @default(now())
  order             Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([createdAt])
}

model Payment {
  id                      String        @id @default(cuid())
  orderId                 String        @unique
  stripeCheckoutSessionId String?
  stripePaymentIntentId   String?
  stripeCustomerId        String?
  amountCents             Int
  currency                String
  status                  PaymentStatus @default(PENDING)
  provider                String        @default("stripe")
  stripeEventId           String?
  paidAt                  DateTime?
  createdAt               DateTime      @default(now())
  updatedAt               DateTime      @updatedAt
  order                   Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([stripePaymentIntentId])
  @@index([stripeCheckoutSessionId])
}

model StripeEvent {
  id            String            @id @default(cuid())
  stripeEventId String            @unique
  type          String
  status        StripeEventStatus @default(RECEIVED)
  errorMessage  String?
  processedAt   DateTime?
  createdAt     DateTime          @default(now())
}

model ConsentRecord {
  id            String   @id @default(cuid())
  visitorId     String?
  analytics     Boolean  @default(false)
  marketing     Boolean  @default(false)
  policyVersion String   @default("v1")
  userAgent     String?
  createdAt     DateTime @default(now())

  @@index([visitorId])
  @@index([createdAt])
}

model VisitorEvent {
  id          String   @id @default(cuid())
  visitorId   String
  eventType   String
  path        String?
  referrer    String?
  utmSource   String?
  utmMedium   String?
  utmCampaign String?
  country     String?
  device      String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@index([visitorId])
  @@index([eventType])
  @@index([createdAt])
}

model OrderStatusEvent {
  id        String      @id @default(cuid())
  orderId   String
  status    OrderStatus
  note      String?
  createdAt DateTime    @default(now())
  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model ArtworkFile {
  id          String            @id @default(cuid())
  orderId     String
  storagePath String
  fileName    String
  mimeType    String
  sizeBytes   Int
  status      ArtworkFileStatus @default(UPLOADED)
  createdAt   DateTime          @default(now())
  order       Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  artworkVersions ArtworkVersion[]

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model ProofFile {
  id                        String          @id @default(cuid())
  orderId                   String
  storagePath               String
  fileName                  String
  mimeType                  String
  sizeBytes                 Int
  status                    ProofFileStatus @default(PENDING_ADMIN_UPLOAD)
  adminNote                 String?
  customerApprovedAt        DateTime?
  customerApprovalIp        String?
  customerChangeRequestNote String?
  createdAt                 DateTime        @default(now())
  updatedAt                 DateTime        @updatedAt
  order                     Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  storedDesigns             StoredDesign[]
  artworkVersions           ArtworkVersion[]

  @@index([orderId])
  @@index([status])
  @@index([createdAt])
}

model PricingMaterialCost {
  id                    String   @id @default(cuid())
  materialKey              String   @unique
  materialCostPerM2        Decimal  @db.Decimal(10, 4)
  mattMaterialCostPerM2    Decimal? @db.Decimal(10, 4)
  freezerMaterialCostPerM2 Decimal? @db.Decimal(10, 4)
  wasteFactorPct           Decimal  @db.Decimal(5, 2)
  minOrderValueNet         Decimal  @db.Decimal(10, 2)
  updatedAt             DateTime @updatedAt
  updatedBy             String?

  @@index([updatedAt])
}

model PricingSettings {
  id                            String   @id @default("default")
  vatPct                        Decimal  @default(19)   @db.Decimal(5, 2)
  roundingStepNet               Decimal  @default(1)    @db.Decimal(10, 2)
  customMaxWidthMm              Int
  customMaxHeightMm             Int
  customMaxQuantity             Int
  designServiceNet              Decimal  @default(40)   @db.Decimal(10, 2)
  designServiceFreeThresholdNet Decimal  @default(2000) @db.Decimal(10, 2)
  physicalProofNet              Decimal  @default(10)   @db.Decimal(10, 2)
  expressNet                    Decimal  @default(9.9)  @db.Decimal(10, 2)
  extraDesignNet                Decimal  @default(19)   @db.Decimal(10, 2)
  platePerColorCostNet          Decimal  @default(40)   @db.Decimal(10, 2)
  inkCostPerM2PerColorNet       Decimal  @default(0.33) @db.Decimal(10, 4)
  digitalCostPerM2Net           Decimal  @default(8)    @db.Decimal(10, 4)
  digitalSellingPricePerM2Net   Decimal  @default(12)   @db.Decimal(10, 4)
  markupTier1Multiplier         Decimal  @default(1.80) @db.Decimal(5, 2)
  markupTier1MaxQty             Int      @default(5000)
  markupTier2Multiplier         Decimal  @default(1.60) @db.Decimal(5, 2)
  markupTier2MaxQty             Int      @default(10000)
  markupTier3Multiplier         Decimal  @default(1.50) @db.Decimal(5, 2)
  labelWeightPerM2Grams         Decimal  @default(150)  @db.Decimal(10, 2)
  shippingTier1MaxKg            Decimal  @default(50)   @db.Decimal(10, 2)
  shippingTier1RateEur          Decimal  @default(10)   @db.Decimal(10, 2)
  shippingTier2MaxKg            Decimal  @default(100)  @db.Decimal(10, 2)
  shippingTier2RateEur          Decimal  @default(9)    @db.Decimal(10, 2)
  shippingTier3RateEur          Decimal  @default(7)    @db.Decimal(10, 2)
  shippingMinCostEur            Decimal  @default(5)    @db.Decimal(10, 2)
  shippingHeavyThresholdKg      Decimal  @default(10)   @db.Decimal(10, 2)
  updatedAt                     DateTime @updatedAt
  updatedBy                     String?

  @@index([updatedAt])
}

model PricingAudit {
  id        String   @id @default(cuid())
  actor     String
  changedAt DateTime @default(now())
  tableName String   @map("table")
  fieldName String   @map("field")
  oldValue  String?
  newValue  String?

  @@index([changedAt])
  @@index([tableName])
  @@index([fieldName])
}

model ChatSession {
  id         String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  visitorId  String       @map("visitor_id")
  pageUrl    String?      @map("page_url")
  createdAt  DateTime     @default(now()) @map("created_at")
  resolvedAt DateTime?    @map("resolved_at")
  messages   ChatMessage[]

  @@map("chat_sessions")
}

model ChatMessage {
  id        String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sessionId String      @map("session_id") @db.Uuid
  sender    String
  content   String
  createdAt DateTime    @default(now()) @map("created_at")
  session   ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId, createdAt])
  @@map("chat_messages")
}
